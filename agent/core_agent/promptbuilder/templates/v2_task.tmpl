{{- if or .Memory.GlobalPrompt .Memory.OccupationPrompt .Memory.ModelPrompt .Memory.WorkerPrompt .Memory.OutputStylePrompt }}
<system_prompt>
{{- if .Memory.GlobalPrompt }}
<global_prompt>
{{ .Memory.GlobalPrompt }}
</global_prompt>
{{ end -}}
{{- if .Memory.OccupationPrompt }}
<occupation_prompt>
{{ .Memory.OccupationPrompt }}
</occupation_prompt>
{{ end -}}
{{- if .Memory.ModelPrompt }}
<model_prompt>
{{ .Memory.ModelPrompt }}
</model_prompt>
{{ end -}}
{{- if .Memory.WorkerPrompt }}
<worker_prompt>
{{ .Memory.WorkerPrompt }}
</worker_prompt>
{{ end -}}
{{- if .Memory.OutputStylePrompt }}
<output_style_prompt>
{{ .Memory.OutputStylePrompt }}
</output_style_prompt>
{{ end -}}
</system_prompt>
{{ end -}}
{{- if or .Memory.EnvPrompt .Memory.SessionGuidancePrompt .Memory.ToolPriorityPrompt .Memory.ProjectPrompt .Memory.ProjectFilePrompt .Memory.SkillPrompts .Memory.InstalledSkillsPrompt }}
<developer_prompt>
{{- if .Memory.SessionGuidancePrompt }}
<session_guidance>
{{ .Memory.SessionGuidancePrompt }}
</session_guidance>
{{ end -}}
{{- if .Memory.EnvPrompt }}
<environment_prompt>
{{ .Memory.EnvPrompt }}
</environment_prompt>
{{ end -}}
{{- if .Memory.ToolPriorityPrompt }}
<tool_priority>
{{ .Memory.ToolPriorityPrompt }}
</tool_priority>
{{ end -}}
{{- if .Memory.ProjectPrompt }}
<project_prompt>
{{ .Memory.ProjectPrompt }}
</project_prompt>
{{ end -}}
{{- if .Memory.ProjectFilePrompt }}
<project_files>
{{ range .Memory.ProjectFilePrompt -}}
<file>
<path>{{ .Path }}</path>
<prompt>
{{ .Prompt }}
</prompt>
</file>
{{ end }}
</project_files>
{{ end -}}
{{- if .Memory.SkillPrompts }}
<worker_skills>
{{ range .Memory.SkillPrompts -}}
<skill>
<name>{{ .Path }}</name>
<content>
{{ .Prompt }}
</content>
</skill>
{{ end }}
</worker_skills>
{{ end -}}
{{- if .Memory.InstalledSkillsPrompt }}
<installed_skills>
{{ .Memory.InstalledSkillsPrompt }}
</installed_skills>
{{ end -}}
</developer_prompt>
{{ end -}}

{{- $memoryContent := memoryContent .Memory }}
{{- if $memoryContent }}
<memory>
{{ $memoryContent }}
</memory>
{{ end -}}

{{- if .ContextInfo }}
<context_window>
<limit_tokens>{{ .ContextInfo.LimitTokens }}</limit_tokens>
<current_tokens>{{ .ContextInfo.CurrentTokens }}</current_tokens>
<current_bytes>{{ .ContextInfo.CurrentBytes }}</current_bytes>
<usage_percent>{{ contextUsagePercent .ContextInfo }}</usage_percent>
</context_window>
{{ end -}}

{{- if .NativeOpenAITools }}
<output_format>
<requirement>本轮使用「原生工具调用」：需要读文件、改代码、整理记忆等，请通过接口提供的 function / tool calling 发起调用；各工具的参数结构由请求里的 JSON Schema 约束，**不必**在对话正文里再贴参数 Schema，也**不要**求你只输出 `{"call_tool":...,"params":...}` 这类整段 JSON。</requirement>
<important_notes>
- 继续推进任务时，以**工具调用**为主；正文可简短说明意图
- **若本轮还有任何工具调用需要执行**，不要结束本轮；只有在**本轮不需要任何工具调用**、任务已完成或必须等待用户输入时，才直接用自然语言回复用户
- 当前仍是多轮中的一步，工具结果会在后续轮次回到上下文
</important_notes>
</output_format>

<final_instruction>请根据对话历史和上述提示继续本轮：该用工具时用工具；只有在本轮不需要任何工具调用、可以结束或需要用户接话时，才用自然语言直接回复用户。</final_instruction>
{{- end }}
