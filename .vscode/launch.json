    "version": "0.2.0",
    "configurations": [
        // CORS_ALLOW_ALL=true task start
        {
            "name": "Launch Backend",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd",
            "args": ["server"],
            // "args": ["server", "--pprof", "--pprof-dump", "--pprof-dump-interval", "60s"],
            "env": {
                "CORS_ALLOW_ALL": "true"
            }
        },
        {
            "name": "TestCreateAndRunTask",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/tests/task_runner",
            "args": [
                "-test.run",
                "TestCreateAndRunTask"
            ],
        },
        {
            "name": "TestCreateAndRunTaskFailed",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/tests/task_runner",
            "args": [
                "-test.run",
                "TestCreateAndRunTaskFailed"
            ],
        },
        {
            "name": "TestRunTaskWithLLMConfig",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/tests/task_runner",
            "args": [
                "-test.run",
                "TestRunTaskWithLLMConfig"
            ],
        }
    ]
}
